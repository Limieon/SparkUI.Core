# Base Settings
SPARKUI_CORE_BASE_URL=http://127.0.0.1:1911
SPARKUI_CORE_HOST=127.0.0.1
SPARKUI_CORE_PORT=1911
SPARKUI_CORE_DEBUG=true
SPARKUI_CORE_DATA_DIR=./data
SPARKUI_CORE_MAX_CONCURRENT_DOWNLOADS=5

# Database Settings
SPARKUI_CORE_DB_HOST=db
SPARKUI_CORE_DB_PORT=5432
SPARKUI_CORE_DB_NAME=sparkui.core
SPARKUI_CORE_DB_USER=sparkui.core
SPARKUI_CORE_DB_PASS=sparkui.core
SPARKUI_CORE_DB_SSL=false
SPARKUI_CORE_DATABASE_URL=postgresql://${SPARKUI_CORE_DB_USER}:${SPARKUI_CORE_DB_PASS}@${SPARKUI_CORE_DB_HOST}:${SPARKUI_CORE_DB_PORT}/${SPARKUI_CORE_DB_NAME}?sslmode=${SPARKUI_CORE_DB_SSL}

# JWT Settings
SPARKUI_CORE_JWT_SECRET=invalid
SPARKUI_CORE_JWT_EXPIRES=1h
SPARKUI_CORE_JWT_REFRESH_SECRET=refresh_secret
SPARKUI_CORE_JWT_REFRESH_EXPIRES=5d

# Cookie Settings
SPARKUI_CORE_COOKIE_ACCESS_TOKEN=sparkui_access_token
SPARKUI_CORE_COOKIE_REFRESH_TOKEN=sparkui_refresh_secret
